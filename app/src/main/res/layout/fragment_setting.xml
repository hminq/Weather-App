<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        tools:context=".presentation.SettingFragment">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="25dp"
            android:layout_height="25dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginStart="16dp"
            android:layout_marginTop="40dp"
            app:backgroundTint="@null"
            android:background="@drawable/ic_arrow_left"
            android:backgroundTint="?attr/colorOnSurfaceVariant" />

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@id/btnBack"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            android:layout_marginStart="16dp"
            android:text="Settings"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="?attr/colorOnBackground" />

        <TextView
            android:id="@+id/tvGeneralTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle"
            android:layout_margin="16dp"
            android:text="General"
            android:textSize="15sp"
            android:textColor="?attr/colorOnBackground" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardGeneral"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvGeneralTitle"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="15dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <View
                    android:id="@+id/generalDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurfaceVariant"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageView
                    android:id="@+id/ivLanguage"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/generalDivider"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_globe"
                    android:padding="6dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvLanguage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivLanguage"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/generalDivider"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="16dp"
                    android:text="Language"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvLanguageValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/generalDivider"
                    app:layout_constraintEnd_toStartOf="@id/ivArrow1"
                    android:layout_marginBottom="16dp"
                    android:layout_marginEnd="8dp"
                    android:text="English"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <ImageView
                    android:id="@+id/ivArrow1"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/generalDivider"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="?attr/colorOnSurfaceVariant" />

                <ImageView
                    android:id="@+id/ivTheme"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/generalDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_lightmode"
                    android:padding="6dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivTheme"
                    app:layout_constraintTop_toBottomOf="@id/generalDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:text="Theme"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/tvThemeValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toBottomOf="@id/generalDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/ivArrow2"
                    android:layout_marginEnd="8dp"
                    android:layout_marginTop="16dp"
                    android:text="Light"
                    android:textColor="?attr/colorOnSurfaceVariant" />

                <ImageView
                    android:id="@+id/ivArrow2"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:layout_constraintTop_toBottomOf="@id/generalDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="?attr/colorOnSurfaceVariant" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvUnitTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardGeneral"
            android:layout_margin="16dp"
            android:text="Unit of measurement"
            android:textSize="15sp"
            android:textColor="?attr/colorOnBackground" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardUnit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvUnitTitle"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="15dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <View
                    android:id="@+id/unitDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurfaceVariant"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageView
                    android:id="@+id/ivWindSpeed"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/unitDivider"
                    android:layout_marginBottom="16dp"
                    android:src="@drawable/ic_wind"
                    android:padding="6dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvWindSpeed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivWindSpeed"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/unitDivider"
                    android:layout_marginBottom="16dp"
                    android:layout_marginStart="16dp"
                    android:text="Wind Speed"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp" />

                <ImageView
                    android:id="@+id/ivTemp"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/unitDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_temp"
                    android:padding="6dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvTemp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivTemp"
                    app:layout_constraintTop_toBottomOf="@id/unitDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginTop="16dp"
                    android:layout_marginStart="16dp"
                    android:text="Temperature"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/tvInfoTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardUnit"
            android:layout_margin="16dp"
            android:text="About"
            android:textSize="15sp"
            android:textColor="?attr/colorOnBackground" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cardInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/tvInfoTitle"
            android:layout_marginHorizontal="16dp"
            android:layout_marginVertical="8dp"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="15dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp">

                <View
                    android:id="@+id/infoDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOnSurfaceVariant"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent" />

                <ImageView
                    android:id="@+id/ivVersion"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/infoDivider"
                    android:src="@drawable/ic_info"
                    android:padding="6dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary" />

                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivVersion"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/infoDivider"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="16dp"
                    android:text="Version"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"/>

                <TextView
                    android:id="@+id/tvVersionValue"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/infoDivider"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginBottom="16dp"
                    android:text="v1.0.0"
                    android:textColor="?attr/colorOnSurfaceVariant"/>

                <ImageView
                    android:id="@+id/ivConnect"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/infoDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:src="@drawable/ic_share"
                    android:padding="6dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_setting_icon"
                    app:tint="?attr/colorPrimary"/>

                <TextView
                    android:id="@+id/tvConnect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintStart_toEndOf="@id/ivVersion"
                    app:layout_constraintTop_toBottomOf="@id/infoDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    android:layout_marginStart="16dp"
                    android:layout_marginTop="16dp"
                    android:text="Contact us"
                    android:textColor="?attr/colorOnSurface"
                    android:textSize="15sp"/>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    app:layout_constraintTop_toBottomOf="@id/infoDivider"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="?attr/colorOnSurfaceVariant"/>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>
</layout>
